# ================================================================
# Agent Skills — Configuration (CLI mode)
# ================================================================

# Provider: "ollama" or "openai" (LM Studio, OpenAI, OpenRouter, etc.)
LLM_PROVIDER=openai

# --- Ollama settings ---
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b

# --- OpenAI-compatible settings (LM Studio, OpenRouter, etc.) ---
OPENAI_BASE_URL=http://localhost:1234/v1
OPENAI_MODEL= openai/gpt-oss-20b
OPENAI_API_KEY=lm-studio
OPENAI_TIMEOUT_SECONDS=1200

# --- General ---
LLM_TEMPERATURE=0.4
SKILLS_DIR=skills

# --- Sessions ---
SESSION_TTL_SECONDS=3600
SESSION_MAX_MESSAGES=100
REFERENCE_FILE_MAX_BYTES=32768
REFERENCE_FILES_TOTAL_MAX_BYTES=262144

# --- Mattermost bot (--mode bot) ---
#MATTERMOST_URL=im.example.com
#MATTERMOST_TOKEN=your_personal_access_token
#MATTERMOST_TEAM=your_team
#MATTERMOST_CHANNEL=your_channel

# --- MCP Servers ---
# Comma-separated list of MCP server prefixes to load
MCP_SERVERS=VICTORIAMETRICS

# VictoriaMetrics MCP Server
MCP_VICTORIAMETRICS_NAME=victoriametrics-mcp
MCP_VICTORIAMETRICS_URL=https://play-mcp.victoriametrics.com
MCP_VICTORIAMETRICS_TRANSPORT=http
#MCP_VICTORIAMETRICS_URL=http://localhost:8080
#MCP_VICTORIAMETRICS_TRANSPORT=sse

# VictoriaMetrics instance settings (for docker-compose)
VM_INSTANCE_ENTRYPOINT=https://play.victoriametrics.com
VM_INSTANCE_TYPE=cluster
MCP_SERVER_MODE=sse
